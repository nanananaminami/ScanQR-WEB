.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #ffffff;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -1rpx 0 rgba(0, 0, 0, 0.06);
  z-index: 999;
}

.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #909399;
}

.tab-bar__item--active {
  color: #0052D9;
}

.tab-bar__text {
  font-size: 20rpx;
  line-height: 1;
}
