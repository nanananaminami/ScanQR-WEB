.cd-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.cd-page {
  padding: 24rpx 24rpx 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.cd-card {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.cd-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.cd-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  font-size: 28rpx;
}

.cd-row__label {
  color: var(--td-text-color-secondary, #909399);
  flex-shrink: 0;
}

.cd-row__value {
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
  word-break: break-all;
}

.cd-row__value--step {
  color: #e37318;
  font-weight: 600;
}

.cd-row__value--blocked {
  color: #e34d59;
  font-weight: 600;
  font-size: 24rpx;
}

/* 工序明细 */
.cd-step {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.cd-step:last-child {
  border-bottom: none;
}

.cd-step__title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-brand-color-7, #0052d9);
  margin-bottom: 8rpx;
}

.cd-step__status-tags {
  display: flex;
  gap: 6rpx;
}

.cd-step__tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.cd-step__tag--prod { background: rgba(0, 82, 217, 0.1); color: #0052D9; }
.cd-step__tag--wip { background: rgba(227, 115, 24, 0.1); color: #e37318; }
.cd-step__tag--wait { background: rgba(144, 147, 153, 0.1); color: #909399; }
.cd-step__tag--qc { background: rgba(0, 168, 112, 0.1); color: #00a870; }
.cd-step__tag--qcskip { background: rgba(0, 168, 112, 0.12); color: #00a870; font-weight: 600; }

.cd-step__info {
  font-size: 22rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 6rpx;
  padding-left: 4rpx;
}

.cd-sla {
  font-size: 22rpx;
  color: #e37318;
  margin-bottom: 10rpx;
  padding: 8rpx 12rpx;
  background: rgba(227, 115, 24, 0.06);
  border-radius: 6rpx;
}

.cd-sla__value {
  font-weight: 600;
}

.cd-dept {
  background: var(--td-bg-color-secondarycontainer, #f9f9f9);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}

.cd-dept__tag {
  margin-bottom: 10rpx;
}

.cd-dept__fields {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 24rpx;
}

.cd-dept__field {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: calc(50% - 12rpx);
}

.cd-dept__field-label {
  font-size: 22rpx;
  color: var(--td-text-color-secondary, #909399);
  white-space: nowrap;
}

.cd-dept__field-value {
  font-size: 24rpx;
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
  word-break: break-all;
}

/* 操作按钮 */
.cd-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 16rpx;
}

.cd-empty {
  padding-top: 200rpx;
}
