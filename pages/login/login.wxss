.login-page {
  padding: 80rpx 48rpx 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.login-hero__icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: #0052D9;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.login-hero__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 12rpx;
}

.login-hero__desc {
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.login-seed {
  margin-top: 80rpx;
  padding: 32rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.login-seed__text {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  text-align: center;
  line-height: 1.6;
}

.login-footer {
  margin-top: auto;
  padding-top: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
}
