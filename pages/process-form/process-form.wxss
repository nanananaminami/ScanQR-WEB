.form-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-top: 200rpx;
}

.form-page {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.form-card {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.form-card__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.form-card__lock {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--td-warning-color-5, #e37318);
}

.form-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.form-card__label {
  color: var(--td-text-color-secondary, #909399);
}

.form-card__value {
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
}

.field-block {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.field-block:last-child {
  border-bottom: none;
}

.field-block__label {
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.field-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.field-switch:last-child {
  border-bottom: none;
}

.field-switch .field-block__label {
  margin-bottom: 0;
}

.form-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 16rpx;
}

.form-empty {
  padding: 120rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.form-empty t-button {
  width: 320rpx;
}
