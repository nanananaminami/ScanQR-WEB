.form-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-top: 200rpx;
}

.form-page {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.form-card {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.form-card__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.form-card__lock {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--td-warning-color-5, #e37318);
}

.form-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.form-card__label {
  color: var(--td-text-color-secondary, #909399);
}

.form-card__value {
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
}

.field-block {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.field-block:last-child {
  border-bottom: none;
}

.field-block__label {
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.field-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.field-switch:last-child {
  border-bottom: none;
}

.field-switch .field-block__label {
  margin-bottom: 0;
}

.field-select {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.field-select__value {
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
}

.field-select__placeholder {
  color: var(--td-text-color-placeholder, #c0c4cc);
}

.field-datetime {
  display: flex;
  flex-direction: column;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.field-datetime:last-child {
  border-bottom: none;
}

.field-datetime__value {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-top: 12rpx;
}

.field-datetime__value--picker {
  color: var(--td-brand-color-7, #0052d9);
}

.field-datetime__placeholder {
  color: var(--td-text-color-placeholder, #c0c4cc);
}

.form-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 16rpx;
}

.form-empty {
  padding: 120rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.form-empty t-button {
  width: 320rpx;
}

/* 搜索选择弹层 */
.search-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
}

.search-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 2001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.search-panel__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.search-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.search-panel__close {
  padding: 8rpx;
}

.search-panel__search {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--td-bg-color-component, #f5f5f5);
  margin: 16rpx 24rpx;
  border-radius: 12rpx;
}

.search-panel__input {
  flex: 1;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  background: transparent;
}

.search-panel__clear {
  font-size: 24rpx;
  color: var(--td-brand-color-7, #0052d9);
  padding: 0 8rpx;
}

.search-panel__list {
  flex: 1;
  max-height: 60vh;
  padding: 0 24rpx 24rpx;
}

.search-panel__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.search-panel__item:active {
  background: var(--td-bg-color-secondarycontainer, #f5f5f5);
}

.search-panel__item--selected {
  color: var(--td-brand-color-7, #0052d9);
  font-weight: 600;
}

.search-panel__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
}
