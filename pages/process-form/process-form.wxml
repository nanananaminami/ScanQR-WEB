<t-navbar title="流程卡填报" leftArrow />

<view class="form-loading" wx:if="{{loading}}">
  <t-loading theme="circular" size="40rpx" text="加载中..." />
</view>

<view class="form-page" wx:if="{{!loading && cardData}}">
  <view class="form-card">
    <view class="form-card__header">
      <view class="form-card__title">{{cardData.prod_name}}</view>
      <view class="form-card__lock">
        <t-icon name="lock-on" size="32rpx" /> 已上锁
      </view>
    </view>
    <view class="form-card__row"><text class="form-card__label">卡号</text><text class="form-card__value">{{cardData.card_no}}</text></view>
    <view class="form-card__row"><text class="form-card__label">工段</text><text class="form-card__value">{{cardData.current_step}}</text></view>
    <view class="form-card__row"><text class="form-card__label">状态</text><text class="form-card__value">{{cardData.status}}</text></view>
    <view class="form-card__row"><text class="form-card__label">锁定人</text><text class="form-card__value">{{cardData.locked_by}}</text></view>
  </view>

  <view class="form-card" wx:if="{{fields.length > 0}}">
    <view class="form-card__header">
      <view class="form-card__title">{{stepName}}填报</view>
    </view>

    <!-- 低代码动态渲染引擎：根据 field.type 分发到对应组件 -->
    <block wx:for="{{fields}}" wx:key="field_name">
      <!-- 文本输入 / 数字输入 -->
      <t-input
        wx:if="{{item.type === 'input' || item.type === 'text' || item.type === 'number'}}"
        label="{{item.displayLabel}}"
        type="{{item.type === 'number' ? 'number' : 'text'}}"
        value="{{formData[item.field_name]}}"
        data-field="{{item.field_name}}"
        placeholder="{{item.placeholder || '请输入'}}"
        bind:change="onInputChange" />

      <!-- 下拉选择 -->
      <view wx:if="{{item.type === 'select'}}" class="field-block">
        <view class="field-block__label">{{item.displayLabel}}</view>
        <view class="field-select" data-field="{{item.field_name}}" data-options="{{item.options}}" bindtap="openSearchSelect">
          <text class="field-select__value {{formData[item.field_name] ? '' : 'field-select__placeholder'}}">
            {{formData[item.field_name] || item.placeholder || '请选择'}}
          </text>
          <t-icon name="chevron-down" size="36rpx" />
        </view>
      </view>

      <!-- 文本域 -->
      <view wx:if="{{item.type === 'textarea'}}" class="field-block">
        <view class="field-block__label">{{item.displayLabel}}</view>
        <t-textarea
          value="{{formData[item.field_name]}}"
          data-field="{{item.field_name}}"
          placeholder="{{item.placeholder || '请输入'}}"
          autosize="{{true}}"
          bind:change="onInputChange" />
      </view>

      <!-- 时间日期：自动记录或手动选择 -->
      <view wx:if="{{item.type === 'datetime' && item.auto_now !== false}}" class="field-datetime">
        <view class="field-block__label">{{item.displayLabel}}</view>
        <view class="field-datetime__value">
          <t-icon name="time" size="32rpx" />
          <text>提交时自动记录</text>
        </view>
      </view>
      <view wx:if="{{item.type === 'datetime' && item.auto_now === false}}" class="field-datetime">
        <view class="field-block__label">{{item.displayLabel}}</view>
        <view class="field-datetime__value field-datetime__value--picker" data-field="{{item.field_name}}" bindtap="openDatePicker">
          <t-icon name="calendar" size="32rpx" />
          <text class="{{formData[item.field_name] ? '' : 'field-datetime__placeholder'}}">{{formData[item.field_name] || '点击选择日期时间'}}</text>
        </view>
      </view>

      <!-- 单选（兼容旧模板） -->
      <view wx:if="{{item.type === 'radio'}}" class="field-block">
        <view class="field-block__label">{{item.displayLabel}}</view>
        <t-radio-group
          value="{{formData[item.field_name]}}"
          data-field="{{item.field_name}}"
          bind:change="onInputChange">
          <t-radio
            wx:for="{{item.options}}"
            wx:for-item="opt"
            wx:key="*this"
            value="{{opt}}"
            label="{{opt}}" />
        </t-radio-group>
      </view>

      <!-- 开关（兼容旧模板） -->
      <view wx:if="{{item.type === 'switch'}}" class="field-switch">
        <view class="field-block__label">{{item.label}}</view>
        <t-switch
          value="{{formData[item.field_name]}}"
          data-field="{{item.field_name}}"
          bind:change="onInputChange" />
      </view>
    </block>
  </view>

  <view class="form-card" wx:if="{{fields.length === 0}}">
    <view class="form-card__title">该工段暂无配置填报模板</view>
  </view>

  <view class="form-actions">
    <t-button theme="primary" block size="large" bind:tap="submitAndUnlock" loading="{{submitting}}">提交并解锁</t-button>
    <t-button theme="default" block bind:tap="cancelAndUnlock" disabled="{{submitting}}">放弃并解锁</t-button>
  </view>
</view>

<view class="form-empty" wx:if="{{!loading && !cardData}}">
  <t-empty description="未获取到流程卡数据，请重新扫码" />
  <t-button theme="primary" bind:tap="goScan">去扫码</t-button>
</view>

<!-- 搜索选择弹层 -->
<view class="search-mask" wx:if="{{showSearchSelect}}" bindtap="closeSearchSelect"></view>
<view class="search-panel" wx:if="{{showSearchSelect}}">
  <view class="search-panel__header">
    <text class="search-panel__title">选择选项</text>
    <view class="search-panel__close" catchtap="closeSearchSelect">
      <t-icon name="close" size="40rpx" />
    </view>
  </view>
  <view class="search-panel__search">
    <t-icon name="search" size="32rpx" style="color:#909399;margin-right:12rpx;" />
    <input class="search-panel__input" value="{{searchKeyword}}" placeholder="输入关键词模糊搜索" placeholder-style="color:#c0c4cc" confirm-type="search" bindinput="onSearchKeywordChange" />
    <text class="search-panel__clear" wx:if="{{searchKeyword}}" catchtap="clearSearchKeyword">清除</text>
  </view>
  <scroll-view class="search-panel__list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="search-panel__item {{searchSelectValue === item ? 'search-panel__item--selected' : ''}}"
          wx:for="{{filteredOptions}}" wx:key="*this"
          data-value="{{item}}" bindtap="selectSearchOption">
      <text>{{item}}</text>
      <t-icon wx:if="{{searchSelectValue === item}}" name="check" size="32rpx" style="color:#0052D9;" />
    </view>
    <view class="search-panel__empty" wx:if="{{filteredOptions.length === 0}}">
      <t-icon name="info-circle" size="40rpx" style="color:#c0c4cc;" />
      <text>未找到匹配 "{{searchKeyword}}"</text>
    </view>
  </scroll-view>
</view>

<t-date-time-picker
  visible="{{datePickerVisible}}"
  value="{{datePickerValue}}"
  format="YYYY-MM-DD HH:mm:ss"
  title="选择日期时间"
  bind:change="onDatePickerConfirm"
  bind:cancel="onDatePickerCancel"
/>
