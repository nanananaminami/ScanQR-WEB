.scan-page {
  padding: 0 32rpx 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.scan-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 0 56rpx;
}

.scan-hero__icon {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: var(--td-brand-color-1, #f2f3ff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.scan-hero__title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--td-text-color-primary, #303133);
}

.scan-hero__desc {
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
  text-align: center;
  padding: 0 40rpx;
}

.scan-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.scan-meta {
  margin-bottom: 24rpx;
}

.scan-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: var(--td-warning-color-1, #fff1e9);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 32rpx;
}

.scan-footer {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}
