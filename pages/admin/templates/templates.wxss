.tpl-page {
  padding: 24rpx 32rpx 80rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.tpl-toolbar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.tpl-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.tpl-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tpl-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tpl-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.tpl-item__name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.tpl-item__meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 6rpx;
}

.tpl-item__actions {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
}

.tpl-item__btn {
  font-size: 28rpx;
  color: #0052D9;
}

.tpl-item__btn--danger {
  color: #e34d59;
}

.tpl-empty {
  padding-top: 160rpx;
}
