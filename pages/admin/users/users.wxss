.users-page {
  padding: 24rpx 32rpx 80rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.filter-chips {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.filter-chip {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  color: var(--td-text-color-secondary, #909399);
}

.filter-chip--active {
  background: #0052D9;
  color: #ffffff;
}

.users-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.user-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.user-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-item__name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.user-item__openid {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 8rpx;
  font-family: monospace;
}

.user-item__meta {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.user-item__action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
  font-size: 28rpx;
  color: #0052D9;
}

.users-empty {
  padding-top: 160rpx;
}
