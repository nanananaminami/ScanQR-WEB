.te-page {
  padding: 24rpx 32rpx 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.te-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.te-card {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.te-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.te-field {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.te-field__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.te-field__type {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 82, 217, 0.08);
  color: #0052D9;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.te-field__mover {
  display: flex;
  gap: 24rpx;
  font-size: 26rpx;
}

.te-field__move {
  color: var(--td-text-color-secondary, #909399);
}

.te-field__del {
  color: #e34d59;
}

.te-row {
  margin-bottom: 20rpx;
}

.te-row--inline {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.te-label {
  display: block;
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 8rpx;
}

.te-row--inline .te-label {
  margin-bottom: 0;
}

.te-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
}

.te-tip {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 8rpx;
}

.te-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx;
  border: 2rpx dashed var(--td-component-border, #dcdfe6);
  border-radius: 16rpx;
  color: #0052D9;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.te-actions {
  margin-top: 8rpx;
}
