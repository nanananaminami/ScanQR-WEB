.te-page {
  padding: 24rpx 32rpx 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.te-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.te-card {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* Tab 切换 */
.te-tabs {
  display: flex;
  gap: 0;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 12rpx;
}

.te-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
  border-radius: 10rpx;
}

.te-tab--active {
  background: #0052D9;
  color: #ffffff;
  font-weight: 600;
}

.te-tab-hint {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  line-height: 1.6;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.te-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.te-field {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.te-field__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.te-field__type {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 82, 217, 0.08);
  color: #0052D9;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.te-field__mover {
  display: flex;
  gap: 24rpx;
  font-size: 26rpx;
}

.te-field__move {
  color: var(--td-text-color-secondary, #909399);
}

.te-field__del {
  color: #e34d59;
}

.te-row {
  margin-bottom: 20rpx;
}

.te-row--inline {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.te-label {
  display: block;
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 8rpx;
}

.te-row--inline .te-label {
  margin-bottom: 0;
}

.te-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
}

.te-tip {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 8rpx;
}

.te-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx;
  border: 2rpx dashed var(--td-component-border, #dcdfe6);
  border-radius: 16rpx;
  color: #0052D9;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.te-actions {
  margin-top: 8rpx;
}

/* 搜索选择弹层 */
.search-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
}

.search-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 2001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.search-panel__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.search-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.search-panel__close {
  padding: 8rpx;
}

.search-panel__search {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--td-bg-color-component, #f5f5f5);
  margin: 16rpx 24rpx;
  border-radius: 12rpx;
}

.search-panel__input {
  flex: 1;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  background: transparent;
}

.search-panel__clear {
  font-size: 24rpx;
  color: var(--td-brand-color-7, #0052d9);
  padding: 0 8rpx;
}

.search-panel__list {
  flex: 1;
  max-height: 60vh;
  padding: 0 24rpx 24rpx;
}

.search-panel__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.search-panel__item:active {
  background: var(--td-bg-color-secondarycontainer, #f5f5f5);
}

.search-panel__item--selected {
  color: var(--td-brand-color-7, #0052d9);
  font-weight: 600;
}

.search-panel__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
}
