.logs-page {
  padding: 0 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.logs-search {
  margin-bottom: 16rpx;
}

.filter-chips {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.filter-chip {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  color: var(--td-text-color-secondary, #909399);
}

.filter-chip--active {
  background: #0052D9;
  color: #ffffff;
}

.logs-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.log-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.log-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-item__card-no {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.log-item__meta {
  font-size: 26rpx;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 8rpx;
}

.log-item__time {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 8rpx;
}

.log-item__form {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  padding-top: 12rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.logs-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.logs-end {
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  padding: 32rpx 0;
}

.logs-empty {
  padding-top: 160rpx;
}
