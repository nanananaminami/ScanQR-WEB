.logs-page {
  padding: 0 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.logs-search {
  margin-bottom: 16rpx;
}

.filter-chips {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.filter-chip {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  color: var(--td-text-color-secondary, #909399);
}

.filter-chip--active {
  background: #0052D9;
  color: #ffffff;
}

.filter-chip--export {
  margin-left: auto;
  background: var(--td-brand-color, #0052D9);
  color: #ffffff;
}

.logs-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.log-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.log-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-item__card-no {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.log-item__meta {
  font-size: 26rpx;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 8rpx;
}

.log-item__time {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 8rpx;
}

.log-item__form {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  padding-top: 12rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.logs-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.logs-end {
  text-align: center;
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  padding: 32rpx 0;
}

.logs-empty {
  padding-top: 160rpx;
}

.logs-export-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
}

.logs-export-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 2001;
  padding: 32rpx;
}

.logs-export-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.logs-export-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.logs-export-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.logs-export-actions t-button {
  flex: 1;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--td-bg-color-component, #f5f5f5);
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-picker__placeholder {
  color: #c0c4cc;
}
