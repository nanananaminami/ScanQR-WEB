<t-navbar title="我的" />

<view class="profile-page">
  <view class="profile-header">
    <view class="profile-avatar">{{user.real_name ? user.real_name[0] : (user.username ? user.username[0] : '?')}}</view>
    <view class="profile-info">
      <view class="profile-name">{{user.real_name || user.username || '未登录'}}</view>
      <t-tag theme="primary" variant="light" size="small">{{roleName || '未登录'}}</t-tag>
    </view>
  </view>

  <view class="profile-section">
    <t-cell-group theme="card">
      <t-cell title="登录账号" note="{{user.username || '-'}}" />
      <t-cell title="所属角色" note="{{roleName || '-'}}" />
      <t-cell title="所属部门" note="{{user.department || '-'}}" />
      <t-cell title="注册时间" note="{{createdText}}" />
      <t-cell title="最近登录" note="{{lastLoginText}}" />
    </t-cell-group>
  </view>

  <view class="profile-section">
    <t-cell-group theme="card">
      <t-cell title="扫码报工" arrow hover bind:click="goScan" />
      <t-cell wx:if="{{permissions.indexOf('card_list') !== -1}}" title="在制卡片管理" arrow hover bind:click="goCards" />
      <t-cell wx:if="{{permissions.indexOf('user_manage') !== -1}}" title="人员管理" arrow hover bind:click="goUsers" />
      <t-cell wx:if="{{permissions.indexOf('role_manage') !== -1}}" title="角色与权限管理" arrow hover bind:click="goRoles" />
      <t-cell title="退出登录" arrow hover bind:click="handleLogout" />
      <t-cell title="清除本地缓存" arrow hover bind:click="clearCache" />
    </t-cell-group>
  </view>

  <view class="profile-footer">
    <text>车间流程卡报工系统 v2.0</text>
  </view>
</view>
