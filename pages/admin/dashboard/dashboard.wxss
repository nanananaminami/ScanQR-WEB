.dashboard {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.dashboard__header {
  margin-bottom: 36rpx;
}

.dashboard__greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 8rpx;
}

.dashboard__subtitle {
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
}

.dashboard__loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  border-radius: 16rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-card--blue { background: #e8f3ff; }
.stat-card--green { background: #e8f7f0; }
.stat-card--orange { background: #fff3e0; }
.stat-card--red { background: #fde8e8; }

.stat-card__value {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-card--blue .stat-card__value { color: #0052D9; }
.stat-card--green .stat-card__value { color: #00a870; }
.stat-card--orange .stat-card__value { color: #ed7b2f; }
.stat-card--red .stat-card__value { color: #e34d59; }

.stat-card__label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.total-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.total-bar__num {
  font-size: 36rpx;
  font-weight: 700;
  color: #0052D9;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
}

.quick-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 36rpx 0;
  font-size: 26rpx;
  color: var(--td-text-color-primary, #303133);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ===== 看板扩展区块 ===== */
.db-section {
  margin-bottom: 32rpx;
}

.db-section__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* WIP 网格 */
.wip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.wip-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.wip-item__name {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.wip-item__count {
  font-size: 32rpx;
  font-weight: 700;
  color: #0052D9;
}

.wip-item__label {
  font-size: 22rpx;
  color: var(--td-text-color-secondary, #909399);
}

/* SLA 瓶颈列表 */
.sla-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sla-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sla-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.sla-item__card {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.sla-item__wait {
  font-size: 26rpx;
  font-weight: 600;
  color: #e37318;
}

.sla-item__path {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.db-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.db-empty__text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  text-align: center;
  line-height: 1.6;
  padding: 0 32rpx;
}
