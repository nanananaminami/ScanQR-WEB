.dashboard {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.dashboard__header {
  margin-bottom: 36rpx;
}

.dashboard__greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 8rpx;
}

.dashboard__subtitle {
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
}

.dashboard__loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  border-radius: 16rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-card--blue { background: #e8f3ff; }
.stat-card--green { background: #e8f7f0; }
.stat-card--orange { background: #fff3e0; }
.stat-card--red { background: #fde8e8; }

.stat-card__value {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-card--blue .stat-card__value { color: #0052D9; }
.stat-card--green .stat-card__value { color: #00a870; }
.stat-card--orange .stat-card__value { color: #ed7b2f; }
.stat-card--red .stat-card__value { color: #e34d59; }

.stat-card__label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.total-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.total-bar__num {
  font-size: 36rpx;
  font-weight: 700;
  color: #0052D9;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
}

.quick-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 36rpx 0;
  font-size: 26rpx;
  color: var(--td-text-color-primary, #303133);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
