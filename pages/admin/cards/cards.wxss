.cards-page {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.cards-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.status-tabs {
  display: flex;
  gap: 12rpx;
  flex: 1;
}

.status-tab {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  color: var(--td-text-color-secondary, #909399);
  white-space: nowrap;
}

.status-tab--active {
  background: #0052D9;
  color: #ffffff;
}

.cards-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: background 0.15s;
}

.card-item:active {
  background: var(--td-bg-color-secondarycontainer, #f5f5f5);
}

.card-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-item__tags {
  display: flex;
  gap: 8rpx;
}

.card-item__no {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.card-item__name {
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.card-item__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.card-item__label {
  color: var(--td-text-color-secondary, #909399);
}

.card-item__value {
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
}

.card-item__action {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
}

.cards-empty {
  padding-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 建卡浮层 */
.create-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.create-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  /* 底距 = 浮层内边距 + 自定义 tabBar 高度 + iPhone 底部安全区，让按钮抬到 tabBar 之上可点 */
  padding: 32rpx 32rpx calc(132rpx + env(safe-area-inset-bottom));
  z-index: 1001;
  max-height: 80vh;
  overflow-y: auto;
}

.create-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 28rpx;
  text-align: center;
}

.create-panel__form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-tip {
  font-size: 22rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
}

.form-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
}

.form-picker__text {
  flex: 1;
}

.form-picker__placeholder {
  color: var(--td-text-color-placeholder, #c0c4cc);
}

/* 只读字段（流程卡号等系统自动生成字段） */
.form-picker--readonly {
  background: var(--td-bg-color-component, #f0f0f0);
  opacity: 0.85;
  cursor: default;
}

/* 搜索选择弹层（z-index 高于建卡面板和 tabBar） */
.search-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
}

.search-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 2001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.search-panel__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.search-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.search-panel__close {
  padding: 8rpx;
}

.search-panel__search {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--td-bg-color-component, #f5f5f5);
  margin: 16rpx 24rpx;
  border-radius: 12rpx;
}

.search-panel__input {
  flex: 1;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  background: transparent;
}

.search-panel__clear {
  font-size: 24rpx;
  color: var(--td-brand-color-7, #0052d9);
  padding: 0 8rpx;
}

.search-panel__list {
  flex: 1;
  max-height: 60vh;
  padding: 0 24rpx 24rpx;
}

.search-panel__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.search-panel__item:active {
  background: var(--td-bg-color-secondarycontainer, #f5f5f5);
}

.search-panel__item--selected {
  color: var(--td-brand-color-7, #0052d9);
  font-weight: 600;
}

.search-panel__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 32rpx;
  font-size: 26rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
}

/* 模板自带 order_no 字段时的提示 */
.form-order-note {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--td-brand-color-7, #0052d9);
  line-height: 1.4;
}

/* 工序列表勾选式 */
.form-row--steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: rgba(0, 82, 217, 0.04);
  border: 2rpx dashed #0052D9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.steps-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.steps-manage {
  font-size: 22rpx;
  color: var(--td-brand-color-7, #0052d9);
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--td-brand-color-7, #0052d9);
  border-radius: 20rpx;
}

.steps-selected {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.steps-chip--selected {
  background: var(--td-brand-color-1, #ecf2fe);
  border: 1rpx solid var(--td-brand-color-7, #0052d9);
}

.steps-chip--selected .steps-chip__index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--td-brand-color-7, #0052d9);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  margin-right: 6rpx;
}

.steps-chip--selected .steps-chip__del {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-left: 4rpx;
  color: var(--td-text-color-secondary, #909399);
}

.steps-empty {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  padding: 16rpx 0;
}

.steps-available {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.steps-no-data {
  font-size: 24rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  text-align: center;
  padding: 20rpx 0;
}

.steps-link {
  color: var(--td-brand-color-7, #0052d9);
}

.steps-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--td-text-color-primary, #303133);
  background: var(--td-bg-color-component, #f0f0f0);
  border: 1rpx solid transparent;
  transition: all 0.15s;
}

.steps-chip--active {
  background: var(--td-brand-color-1, #ecf2fe);
  color: var(--td-brand-color-7, #0052d9);
  border-color: var(--td-brand-color-7, #0052d9);
}

.steps-custom {
  border-top: 1rpx solid var(--td-component-border, #e5e5e5);
  padding-top: 12rpx;
  margin-top: 4rpx;
}

.steps-custom__toggle {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--td-text-color-secondary, #909399);
  padding: 8rpx 0;
}

.steps-custom__input {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 8rpx;
}

.steps-custom__input > t-input {
  flex: 1;
}

.form-label--required {
  color: var(--td-brand-color-7, #0052d9);
  font-weight: 600;
}

.create-panel__tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  line-height: 1.6;
}

.create-panel__actions {
  display: flex;
  gap: 24rpx;
  margin-top: 28rpx;
}

.create-panel__actions > view,
.create-panel__actions > t-button {
  flex: 1;
}
