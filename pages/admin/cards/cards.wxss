.cards-page {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-bar__item {
  padding: 14rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  color: var(--td-text-color-secondary, #909399);
}

.filter-bar__item--active {
  background: #0052D9;
  color: #ffffff;
}

.cards-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-item__no {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.card-item__name {
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.card-item__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.card-item__label {
  color: var(--td-text-color-secondary, #909399);
}

.card-item__value {
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
}

.card-item__action {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
}

.cards-empty {
  padding-top: 160rpx;
}
