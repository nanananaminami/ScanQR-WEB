.cards-page {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.cards-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.status-tabs {
  display: flex;
  gap: 12rpx;
  flex: 1;
}

.status-tab {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  color: var(--td-text-color-secondary, #909399);
  white-space: nowrap;
}

.status-tab--active {
  background: #0052D9;
  color: #ffffff;
}

.cards-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-item__tags {
  display: flex;
  gap: 8rpx;
}

.card-item__no {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.card-item__name {
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.card-item__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.card-item__label {
  color: var(--td-text-color-secondary, #909399);
}

.card-item__value {
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
}

.card-item__action {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
}

.cards-empty {
  padding-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 建卡浮层 */
.create-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.create-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  /* 底距 = 浮层内边距 + 自定义 tabBar 高度 + iPhone 底部安全区，让按钮抬到 tabBar 之上可点 */
  padding: 32rpx 32rpx calc(132rpx + env(safe-area-inset-bottom));
  z-index: 1001;
  max-height: 80vh;
  overflow-y: auto;
}

.create-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 28rpx;
  text-align: center;
}

.create-panel__form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
}

.form-picker__text {
  flex: 1;
}

.form-picker__placeholder {
  color: var(--td-text-color-placeholder, #c0c4cc);
}

.create-panel__tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
  line-height: 1.6;
}

.create-panel__actions {
  display: flex;
  gap: 24rpx;
  margin-top: 28rpx;
}

.create-panel__actions > view,
.create-panel__actions > t-button {
  flex: 1;
}
