<t-navbar title="在制卡片管理" />

<view class="cards-page">
  <view class="cards-toolbar">
    <view class="status-tabs">
      <view class="status-tab {{statusFilter === item ? 'status-tab--active' : ''}}"
            wx:for="{{statusTabs}}" wx:key="*this"
            data-status="{{item}}" bindtap="onStatusTabChange">{{item}}</view>
    </view>
    <t-button wx:if="{{canCreate}}" theme="primary" size="small" bind:tap="openCreate">+ 建卡</t-button>
  </view>

  <view class="cards-loading" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="card-list" wx:if="{{cards.length > 0}}">
      <view class="card-item" wx:for="{{cards}}" wx:key="_id">
        <view class="card-item__header">
          <view class="card-item__no">{{item.card_no}}</view>
          <view class="card-item__tags">
            <t-tag theme="{{item.statusTheme}}" variant="light" size="small">{{item.status}}</t-tag>
            <t-tag wx:if="{{item.is_locked}}" theme="warning" variant="light" size="small">{{item.lockedText}}</t-tag>
          </view>
        </view>
        <view class="card-item__name">{{item.prod_name}}</view>
        <view class="card-item__row">
          <text class="card-item__label">工段</text>
          <text class="card-item__value">{{item.current_step}}</text>
        </view>
        <view class="card-item__row" wx:if="{{item.is_locked}}">
          <text class="card-item__label">持有人</text>
          <text class="card-item__value">{{item.locked_by || '未知'}}</text>
        </view>
        <view class="card-item__row" wx:if="{{item.is_locked}}">
          <text class="card-item__label">锁定时间</text>
          <text class="card-item__value">{{item.lockTimeText}}</text>
        </view>
        <view class="card-item__action">
          <t-button theme="default" size="small" variant="text" data-card-no="{{item.card_no}}" bind:tap="goTrace">
            追溯
          </t-button>
          <t-button theme="primary" size="small" variant="text" data-index="{{index}}" bind:tap="cardActions">
            更多
          </t-button>
        </view>
      </view>
    </view>

    <view class="cards-empty" wx:else>
      <t-empty description="该状态下暂无流程卡" />
      <t-button wx:if="{{canCreate && statusFilter === '加工中'}}" theme="primary" bind:tap="openCreate" style="margin-top: 24rpx;">新建流程卡</t-button>
    </view>
  </block>
</view>

<!-- 建卡浮层 -->
<view class="create-mask" wx:if="{{showCreate}}" bindtap="closeCreate"></view>
<view class="create-panel" wx:if="{{showCreate}}">
  <view class="create-panel__title">新建流程卡</view>
  <view class="create-panel__form">
    <view class="form-row">
      <text class="form-label">绑定模板 *</text>
      <view class="form-picker" bindtap="pickTemplate">
        <text class="form-picker__text {{createTemplateName ? '' : 'form-picker__placeholder'}}">{{createTemplateName || '请选择模板'}}</text>
        <t-icon name="chevron-right" size="32rpx" />
      </view>
    </view>
    <view class="form-row">
      <text class="form-label">流程卡号 *</text>
      <t-input value="{{createForm.card_no}}" placeholder="如 WO-20260713-0001" data-field="card_no" bind:change="onCreateFormChange" />
    </view>
    <view class="form-row">
      <text class="form-label">产品名称 *</text>
      <t-input value="{{createForm.prod_name}}" placeholder="如 轴承外圈加工" data-field="prod_name" bind:change="onCreateFormChange" />
    </view>
  </view>
  <view class="create-panel__tip">工段将自动取自所选模板；建卡后可立即生成二维码。</view>
  <view class="create-panel__actions">
    <t-button theme="default" variant="outline" bind:tap="closeCreate">取消</t-button>
    <t-button theme="primary" bind:tap="submitCreate" loading="{{creating}}">创建</t-button>
  </view>
</view>
