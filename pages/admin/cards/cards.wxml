<t-navbar title="在制流转卡管理" />

<view class="cards-page">
  <view class="cards-toolbar">
    <view class="status-tabs">
      <view class="status-tab {{statusFilter === item ? 'status-tab--active' : ''}}"
            wx:for="{{statusTabs}}" wx:key="*this"
            data-status="{{item}}" bindtap="onStatusTabChange">{{item}}</view>
    </view>
    <t-button wx:if="{{canCreate}}" theme="primary" size="small" bind:tap="openCreate">+ 建卡</t-button>
  </view>

  <view class="cards-loading" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="card-list" wx:if="{{cards.length > 0}}">
      <view class="card-item" wx:for="{{cards}}" wx:key="_id" data-order-no="{{item.orderNo}}" bindtap="openDetail">
        <view class="card-item__header">
          <view class="card-item__no">{{item.orderNo}}</view>
          <view class="card-item__tags">
            <t-tag theme="{{item.statusTheme}}" variant="light" size="small">{{item.status}}</t-tag>
            <t-tag wx:if="{{item.is_locked}}" theme="warning" variant="light" size="small">{{item.lockedText}}</t-tag>
          </view>
        </view>
        <view class="card-item__name">{{item.projectLabel}}</view>
        <view class="card-item__row">
          <text class="card-item__label">工单号</text>
          <text class="card-item__value">{{item.workOrderNo || '-'}}</text>
        </view>
        <view class="card-item__row">
          <text class="card-item__label">工序数</text>
          <text class="card-item__value">{{item.stepCount}} 道</text>
        </view>
        <view class="card-item__row" wx:if="{{item.is_locked}}">
          <text class="card-item__label">持有人</text>
          <text class="card-item__value">{{item.locked_by || '未知'}}</text>
        </view>
        <view class="card-item__row" wx:if="{{item.is_locked}}">
          <text class="card-item__label">锁定时间</text>
          <text class="card-item__value">{{item.lockTimeText}}</text>
        </view>
        <view class="card-item__action" catchtap="noop">
          <t-button theme="default" size="small" variant="text" data-order-no="{{item.orderNo}}" bind:tap="viewQrCode">
            二维码
          </t-button>
          <t-button theme="default" size="small" variant="text" data-order-no="{{item.orderNo}}" bind:tap="goTrace">
            追溯
          </t-button>
          <t-button theme="primary" size="small" variant="text" data-index="{{index}}" bind:tap="cardActions">
            更多
          </t-button>
        </view>
      </view>
    </view>

    <view class="cards-empty" wx:else>
      <t-empty description="该状态下暂无流转卡" />
      <t-button wx:if="{{canCreate && statusFilter === '加工中'}}" theme="primary" bind:tap="openCreate" style="margin-top: 24rpx;">新建流转卡</t-button>
    </view>
  </block>
</view>

<!-- 建卡浮层 -->
<view class="create-mask" wx:if="{{showCreate}}" bindtap="closeCreate"></view>
<view class="create-panel" wx:if="{{showCreate}}">
  <view class="create-panel__title">新建流转卡</view>
  <view class="create-panel__form">
    <view class="form-row">
      <text class="form-label">选择模板 *</text>
      <view class="form-picker" bindtap="pickTemplate">
        <text class="form-picker__text {{selectedTemplateName ? '' : 'form-picker__placeholder'}}">{{selectedTemplateName || '请选择模板'}}</text>
        <t-icon name="chevron-right" size="32rpx" />
      </view>
    </view>

    <!-- 流程卡号（固定字段，提交时自动生成） -->
    <view class="form-row">
      <text class="form-label">流程卡号</text>
      <view class="form-picker form-picker--readonly">
        <text class="form-picker__text form-picker__placeholder">提交时自动生成（工单号 + 两位顺序码）</text>
        <t-icon name="time" size="32rpx" style="color:#909399;" />
      </view>
    </view>

    <!-- 工单号（固定字段，用户输入） -->
    <view class="form-row">
      <text class="form-label">工单号 *</text>
      <t-input value="{{createForm.workOrderNo}}" placeholder="如 A260130011" data-field="workOrderNo" bind:change="onCreateFormChange" />
    </view>

    <!-- 动态表头字段（过滤掉系统固定字段 order_no / work_order_no） -->
    <block wx:if="{{selectedTemplate}}">
      <view class="form-row" wx:for="{{selectedTemplate.header_fields}}" wx:key="field_name" wx:if="{{item.field_name !== 'order_no' && item.field_name !== 'work_order_no'}}">
        <text class="form-label">{{item.label}}{{item.required ? ' *' : ''}}</text>
        <t-input wx:if="{{item.type === 'input' || item.type === 'text'}}" value="{{headerForm[item.field_name]}}" data-field="{{item.field_name}}" placeholder="请输入" bind:change="onHeaderFormChange" />
        <t-input wx:elif="{{item.type === 'number'}}" value="{{headerForm[item.field_name]}}" type="number" data-field="{{item.field_name}}" placeholder="0" bind:change="onHeaderFormChange" />
        <t-textarea wx:elif="{{item.type === 'textarea'}}" value="{{headerForm[item.field_name]}}" data-field="{{item.field_name}}" placeholder="请输入" autosize="{{true}}" bind:change="onHeaderFormChange" />
        <view wx:elif="{{item.type === 'select'}}" class="form-picker" data-field="{{item.field_name}}" bindtap="openSearchSelect">
          <text class="{{headerForm[item.field_name] ? '' : 'form-picker__placeholder'}}">{{headerForm[item.field_name] || '请选择'}}</text>
          <t-icon name="chevron-right" size="32rpx" data-field="{{item.field_name}}" catchtap="openSearchSelect" />
        </view>
        <view wx:elif="{{item.type === 'datetime' && item.auto_now !== false}}" class="form-picker" data-field="{{item.field_name}}" bindtap="fillHeaderTime">
          <text class="{{headerForm[item.field_name] ? '' : 'form-picker__placeholder'}}">{{headerForm[item.field_name] || '点击记录时间'}}</text>
          <t-icon name="time" size="32rpx" />
        </view>
        <view wx:elif="{{item.type === 'datetime' && item.auto_now === false}}" class="form-picker" data-field="{{item.field_name}}" bindtap="openDatePicker">
          <text class="{{headerForm[item.field_name] ? '' : 'form-picker__placeholder'}}">{{headerForm[item.field_name] || '选择日期时间'}}</text>
          <t-icon name="calendar" size="32rpx" />
        </view>
      </view>
    </block>

    <!-- 工序列表：勾选式 -->
    <view class="form-row form-row--steps">
      <view class="steps-header">
        <text class="form-label form-label--required">工序列表 *</text>
        <text class="steps-manage" bindtap="goManageProcesses">管理工序</text>
      </view>

      <view class="steps-selected" wx:if="{{selectedProcesses.length > 0}}">
        <view class="steps-chip steps-chip--selected" wx:for="{{selectedProcesses}}" wx:key="*this">
          <text class="steps-chip__index">{{index + 1}}</text>
          <text class="steps-chip__name">{{item}}</text>
          <view class="steps-chip__del" data-name="{{item}}" catchtap="removeProcess">
            <t-icon name="close" size="24rpx" />
          </view>
        </view>
      </view>
      <view class="steps-empty" wx:if="{{selectedProcesses.length === 0}}">
        <t-icon name="info-circle" size="28rpx" style="color:#909399;margin-right:8rpx;" />
        <text>请在下方选择工序（可多选，按选择顺序排列）</text>
      </view>

      <view class="steps-available" wx:if="{{processList.length > 0}}">
        <view class="steps-chip {{selectedProcesses.indexOf(item) !== -1 ? 'steps-chip--active' : ''}}"
              wx:for="{{processList}}" wx:key="*this"
              data-name="{{item}}" bindtap="toggleProcess">
          <t-icon wx:if="{{selectedProcesses.indexOf(item) !== -1}}" name="check" size="28rpx" style="margin-right:4rpx;" />
          <text>{{item}}</text>
        </view>
      </view>
      <view class="steps-no-data" wx:if="{{processList.length === 0}}">
        <text>暂无可选工序，请先</text>
        <text class="steps-link" bindtap="goManageProcesses">管理工序列表</text>
        <text>添加</text>
      </view>

      <view class="steps-custom">
        <view class="steps-custom__toggle" bindtap="toggleCustomInput">
          <t-icon name="{{showCustomInput ? 'close' : 'add'}}" size="28rpx" style="margin-right:4rpx;" />
          <text>自定义工序</text>
        </view>
        <view class="steps-custom__input" wx:if="{{showCustomInput}}">
          <t-input value="{{customProcessText}}" placeholder="输入工序名称" bind:change="onCustomProcessInput" />
          <t-button theme="primary" size="small" bind:tap="addCustomProcess">添加</t-button>
        </view>
      </view>
    </view>
  </view>
  <view class="create-panel__actions">
    <t-button theme="default" variant="outline" bind:tap="closeCreate">取消</t-button>
    <t-button theme="primary" bind:tap="submitCreate" loading="{{creating}}">创建</t-button>
  </view>
</view>

<!-- 搜索选择弹层（可模糊查询） -->
<view class="search-mask" wx:if="{{showSearchSelect}}" bindtap="closeSearchSelect"></view>
<view class="search-panel" wx:if="{{showSearchSelect}}">
  <view class="search-panel__header">
    <text class="search-panel__title">选择 {{searchSelectLabel}}</text>
    <view class="search-panel__close" catchtap="closeSearchSelect">
      <t-icon name="close" size="40rpx" />
    </view>
  </view>
  <view class="search-panel__search">
    <t-icon name="search" size="32rpx" style="color:#909399;margin-right:12rpx;" />
    <input class="search-panel__input" value="{{searchKeyword}}" placeholder="输入关键词模糊搜索" placeholder-style="color:#c0c4cc" confirm-type="search" bindinput="onSearchKeywordChange" />
    <text class="search-panel__clear" wx:if="{{searchKeyword}}" catchtap="clearSearchKeyword">清除</text>
  </view>
  <scroll-view class="search-panel__list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="search-panel__item {{searchSelectValue === item ? 'search-panel__item--selected' : ''}}"
          wx:for="{{filteredOptions}}" wx:key="*this"
          data-value="{{item}}" bindtap="selectSearchOption">
      <text>{{item}}</text>
      <t-icon wx:if="{{searchSelectValue === item}}" name="check" size="32rpx" style="color:#0052D9;" />
    </view>
    <view class="search-panel__empty" wx:if="{{filteredOptions.length === 0}}">
      <t-icon name="info-circle" size="40rpx" style="color:#c0c4cc;" />
      <text wx:if="{{searchSelectOptions.length === 0}}">该字段无配置选项（请先在字典管理添加）</text>
      <text wx:else>未找到匹配 "{{searchKeyword}}"</text>
    </view>
  </scroll-view>
</view>

<t-date-time-picker
  visible="{{datePickerVisible}}"
  value="{{datePickerValue}}"
  format="YYYY-MM-DD HH:mm:ss"
  title="选择日期时间"
  bind:change="onDatePickerConfirm"
  bind:cancel="onDatePickerCancel"
/>
