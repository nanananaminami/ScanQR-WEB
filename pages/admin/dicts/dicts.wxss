.dicts-page {
  padding: 24rpx 32rpx 80rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.dicts-toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24rpx;
}

.dicts-loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.dict-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dict-item {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dict-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dict-item__name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.dict-item__id {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-bottom: 16rpx;
}

.dict-item__options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.dict-tag {
  padding: 6rpx 20rpx;
  background: var(--td-bg-color-component, #f0f0f0);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--td-text-color-primary, #303133);
}

.dict-item__actions {
  display: flex;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--td-component-border, #f0f0f0);
}

.dict-item__btn {
  font-size: 28rpx;
  color: #0052D9;
}

.dict-item__btn--danger {
  color: #e34d59;
}

.dicts-empty {
  padding-top: 160rpx;
}

/* 编辑浮层 */
.dict-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.dict-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
}

.dict-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 28rpx;
  text-align: center;
}

.dict-panel__form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}

.dict-panel__actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.dict-panel__actions > view,
.dict-panel__actions > t-button {
  flex: 1;
}
