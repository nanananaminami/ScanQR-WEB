<t-navbar title="生成流程卡二维码" leftArrow />

<view class="qr-page">
  <view class="qr-form-card">
    <view class="qr-form-card__title">物料信息</view>
    <t-input
      label="流程卡号"
      placeholder="如 WO-20260712-01"
      value="{{form.cardNo}}"
      data-field="cardNo"
      bind:change="onInputChange"
      borderless />
    <t-input
      label="产品名称"
      placeholder="如 轴承外圈加工"
      value="{{form.prodName}}"
      data-field="prodName"
      bind:change="onInputChange"
      borderless />
    <t-input
      label="批次号"
      placeholder="选填"
      value="{{form.batchNo}}"
      data-field="batchNo"
      bind:change="onInputChange"
      borderless />
    <t-input
      label="工段"
      placeholder="如 质检工段"
      value="{{form.stepName}}"
      data-field="stepName"
      bind:change="onInputChange"
      borderless />
  </view>

  <view class="qr-preview">
    <view class="qr-preview__box" wx:if="{{qrReady}}">
      <canvas
        type="2d"
        id="qrCanvas"
        class="qr-preview__canvas"
        style="width:{{canvasSize}}px;height:{{canvasSize}}px;" />
      <view class="qr-preview__label">{{form.cardNo || '流程卡'}}</view>
    </view>
    <view class="qr-preview__empty" wx:else>
      <t-icon name="image" size="96rpx" />
      <view class="qr-preview__empty-text">填写信息后点击生成</view>
    </view>
  </view>

  <view class="qr-actions">
    <t-button theme="primary" block size="large" bind:tap="handleGenerate" loading="{{generating}}">
      生成二维码
    </t-button>
    <t-button theme="default" block bind:tap="handleSave" disabled="{{!qrReady}}" loading="{{saving}}">
      保存到相册
    </t-button>
  </view>

  <view class="qr-tip">
    <t-icon name="info-circle" size="32rpx" />
    <text>二维码内容为流程卡号，生成后可保存至相册打印贴附</text>
  </view>
</view>

<t-message id="t-message" />
