<t-navbar title="生成流转卡二维码" leftArrow />

<view class="qr-page">
  <view class="qr-form-card">
    <view class="qr-form-card__title">流转卡信息</view>
    <t-input
      label="工单号"
      placeholder="如 A260130011"
      value="{{form.orderNo}}"
      data-field="orderNo"
      bind:change="onInputChange"
      borderless />
    <t-input
      label="项目名称"
      placeholder="如 G2556C-L"
      value="{{form.projectName}}"
      data-field="projectName"
      bind:change="onInputChange"
      borderless />
    <t-input
      label="批次号"
      placeholder="选填"
      value="{{form.batchNo}}"
      data-field="batchNo"
      bind:change="onInputChange"
      borderless />
  </view>

  <view class="qr-preview">
    <view class="qr-preview__box" wx:if="{{qrReady}}">
      <canvas
        type="2d"
        id="qrCanvas"
        class="qr-preview__canvas"
        style="width:{{canvasSize}}px;height:{{canvasSize}}px;" />
      <view class="qr-preview__label">{{form.orderNo || '流转卡'}}</view>
    </view>
    <view class="qr-preview__empty" wx:else>
      <t-icon name="image" size="96rpx" />
      <view class="qr-preview__empty-text">填写信息后点击生成</view>
    </view>
  </view>

  <view class="qr-actions">
    <t-button theme="primary" block size="large" bind:tap="handleGenerate" loading="{{generating}}">
      生成二维码
    </t-button>
    <t-button theme="default" block bind:tap="handleSave" disabled="{{!qrReady}}" loading="{{saving}}">
      保存到相册
    </t-button>
  </view>

  <view class="qr-tip">
    <t-icon name="info-circle" size="32rpx" />
    <text>二维码内容为工单号，生成后可保存至相册打印贴附</text>
  </view>
</view>

<t-message id="t-message" />
