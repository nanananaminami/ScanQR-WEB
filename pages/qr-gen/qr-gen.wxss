.qr-page {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.qr-form-card {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 8rpx 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.qr-form-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  padding: 24rpx 0 12rpx;
}

.qr-preview {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.qr-preview__box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.qr-preview__canvas {
  background: #ffffff;
}

.qr-preview__label {
  margin-top: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.qr-preview__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0;
  color: var(--td-text-color-secondary, #909399);
}

.qr-preview__empty-text {
  font-size: 26rpx;
}

.qr-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.qr-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: var(--td-warning-color-1, #fff1e9);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
}
