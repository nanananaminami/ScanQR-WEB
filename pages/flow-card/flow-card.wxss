.fc-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-top: 200rpx;
}

.fc-page {
  padding: 24rpx 24rpx 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 头部信息 ===== */
.fc-header {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.fc-header__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--td-text-color-primary, #303133);
  text-align: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.fc-header__rows {
  display: flex;
  flex-wrap: wrap;
}

.fc-header__row {
  width: 50%;
  padding: 10rpx 0;
  display: flex;
  align-items: center;
}

.fc-header__row--full {
  width: 100%;
}

.fc-header__label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  margin-right: 12rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.fc-header__value {
  font-size: 26rpx;
  color: var(--td-text-color-primary, #303133);
  font-weight: 500;
  flex: 1;
}

.fc-header__value--lock {
  color: var(--td-warning-color-5, #e37318);
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

.fc-header-select {
  display: flex;
  align-items: center;
  flex: 1;
  font-size: 26rpx;
  color: var(--td-brand-color-7, #0052d9);
}

/* ===== 动态工序列表（卡片式） ===== */
.fc-steps {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.fc-step {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.fc-step__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-brand-color-7, #0052d9);
  border-bottom: 2rpx solid #eee;
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
}

.fc-step__devices {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.fc-step__device {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fc-step__device-label {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #909399);
  white-space: nowrap;
  flex-shrink: 0;
}

.fc-step__depts {
  background: var(--td-bg-color-secondarycontainer, #f9f9f9);
  border-radius: 12rpx;
  padding: 20rpx;
}

.fc-dept {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx dashed #ddd;
}

.fc-dept:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.fc-dept--qc {
  /* 品质行可加微弱区分色 */
}

.fc-dept__tag {
  margin-bottom: 12rpx;
}

.fc-dept__fields {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 20rpx;
}

.fc-dept__field {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.fc-dept__field--full {
  width: 100%;
}

.fc-dept__field-label {
  font-size: 22rpx;
  color: var(--td-text-color-secondary, #909399);
}

.fc-dept__select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: var(--td-brand-color-7, #0052d9);
}

.fc-dept__select--ph {
  color: var(--td-text-color-placeholder, #c0c4cc);
  font-size: 26rpx;
}

.fc-dept__time {
  padding: 8rpx 0;
  font-size: 26rpx;
  color: var(--td-brand-color-7, #0052d9);
}

.fc-time-cell {
  font-size: 26rpx;
  color: var(--td-brand-color-7, #0052d9);
  padding: 4rpx 0;
}

.fc-time-cell__placeholder {
  color: var(--td-text-color-placeholder, #c0c4cc);
  font-size: 26rpx;
}

/* ===== 入库签字 ===== */
.fc-signature {
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx dashed #ccc;
}

.fc-signature__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.fc-signature__row {
  display: flex;
}

.fc-signature__item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fc-signature__item:first-child {
  padding-right: 24rpx;
  border-right: 1rpx solid var(--td-component-border, #f0f0f0);
}

.fc-signature__item:last-child {
  padding-left: 24rpx;
}

.fc-signature__label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary, #909399);
  white-space: nowrap;
}

/* ===== 操作按钮 ===== */
.fc-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 16rpx;
}

/* ===== 空状态 ===== */
.fc-empty {
  padding: 120rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.fc-empty t-button {
  width: 320rpx;
}
