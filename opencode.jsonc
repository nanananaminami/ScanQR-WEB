{
  "$schema": "https://opencode.ai/config.json",
  "shell": "zsh",
  "watcher": {
    "ignore": [
      ".cloudbase/**",
      "node_modules/**",
      "miniprogram_npm/**"
    ]
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "external_directory": "deny"
  },
  "skills": {
    "paths": [".opencode/skills"]
  },
  "instructions": [
    "AGENTS.md"
  ]
}
