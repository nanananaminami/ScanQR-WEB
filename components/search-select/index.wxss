.search-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
}

.search-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 2001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.search-panel__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--td-component-border, #f0f0f0);
}

.search-panel__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #303133);
}

.search-panel__close {
  padding: 8rpx;
}

.search-panel__search {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--td-bg-color-component, #f5f5f5);
  margin: 16rpx 24rpx;
  border-radius: 12rpx;
}

.search-panel__input {
  flex: 1;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  background: transparent;
}

.search-panel__clear {
  font-size: 24rpx;
  color: var(--td-brand-color-7, #0052d9);
  padding: 0 8rpx;
}

.search-panel__list {
  flex: 1;
  max-height: 60vh;
  padding: 0 24rpx 24rpx;
}

.search-panel__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  font-size: 28rpx;
  color: var(--td-text-color-primary, #303133);
  border-bottom: 1rpx solid var(--td-component-border, #f5f5f5);
}

.search-panel__item:active {
  background: var(--td-bg-color-secondarycontainer, #f5f5f5);
}

.search-panel__item--selected {
  color: var(--td-brand-color-7, #0052d9);
  font-weight: 600;
}

.search-panel__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: var(--td-text-color-placeholder, #c0c4cc);
}
